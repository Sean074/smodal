
$ Validation: Cantilever beam — fundamental bending frequency (SOL 103)
$ Euler-Bernoulli closed-form: f1 = (1.875^2 / 2*pi) * sqrt(E*I / (rho*A*L^4))
$
$ Geometry:  L = 10 m, 10 equal CBAR elements (1 m each), 11 nodes
$ Material:  Steel — E = 200 GPa, nu = 0.3, rho = 7850 kg/m^3
$ Section:   Solid square, side = 0.31623 m
$              A  = 0.1 m^2
$              I1 = I2 = a^4/12 = 8.333e-4 m^4
$ BCs:       Encastre at node 1 (x = 0)
$
$ Calculation:
$   E*I         = 2e11 * 8.333e-4 = 1.6667e8 N.m^2
$   rho*A*L^4   = 7850 * 0.1 * 10^4 = 7.85e6 kg.m^3
$   sqrt(E*I / rho*A*L^4) = sqrt(21.23) = 4.608 rad/s
$   f1 = (1.875^2 / 2*pi) * 4.608 = 0.5596 * 4.608 = 2.579 Hz
$
$ Expected:  f1 (mode 1 bending in XZ) ≈ 2.58 Hz
$            f2 (mode 2 bending in XY) ≈ 2.58 Hz  (symmetric square section)
$ Units:     SI (m, N, kg, Pa)
$
SOL 103
$
SUBCASE 1
  TITLE  = Cantilever Normal Modes — Validation
  SPC    = 1
  METHOD = 20
$
BEGIN BULK
$
$ ------------------------------------------------------------------ NODES
$ GRID, GID, CP, X1,  X2,  X3, CD, PS, SEID
GRID,  1, , 0.0,  0.0, 0.0
GRID,  2, , 1.0,  0.0, 0.0
GRID,  3, , 2.0,  0.0, 0.0
GRID,  4, , 3.0,  0.0, 0.0
GRID,  5, , 4.0,  0.0, 0.0
GRID,  6, , 5.0,  0.0, 0.0
GRID,  7, , 6.0,  0.0, 0.0
GRID,  8, , 7.0,  0.0, 0.0
GRID,  9, , 8.0,  0.0, 0.0
GRID, 10, , 9.0,  0.0, 0.0
GRID, 11, , 10.0, 0.0, 0.0
$
$ --------------------------------------------------------------- MATERIAL
$ MAT1, MID, E,      G,        NU,  RHO
$ Distributed mass from rho — no added mass
MAT1, 1, 2.0e11, 7.692e10, 0.3, 7850.0
$
$ ------------------------------------------------------------- PROPERTIES
$ PBAR, PID, MID, A,   I1,       I2,       J
$ Solid square: a = 0.31623 m
PBAR, 1, 1, 0.1, 8.333e-4, 8.333e-4, 1.406e-3
$ +,   C1,      C2,       D1,       D2,       E1,        E2,       F1,       F2
+,    0.15811, 0.15811, -0.15811, 0.15811, -0.15811, -0.15811, 0.15811, -0.15811
$
$ --------------------------------------------------------------- ELEMENTS
$ CBAR, EID, PID, GA, GB, X1,  X2,  X3
$ Orientation vector (0,1,0): local y = global Y
CBAR,  1, 1,  1,  2, 0.0, 1.0, 0.0
CBAR,  2, 1,  2,  3, 0.0, 1.0, 0.0
CBAR,  3, 1,  3,  4, 0.0, 1.0, 0.0
CBAR,  4, 1,  4,  5, 0.0, 1.0, 0.0
CBAR,  5, 1,  5,  6, 0.0, 1.0, 0.0
CBAR,  6, 1,  6,  7, 0.0, 1.0, 0.0
CBAR,  7, 1,  7,  8, 0.0, 1.0, 0.0
CBAR,  8, 1,  8,  9, 0.0, 1.0, 0.0
CBAR,  9, 1,  9, 10, 0.0, 1.0, 0.0
CBAR, 10, 1, 10, 11, 0.0, 1.0, 0.0
$
$ ----------------------------------------------------------- CONSTRAINTS
$ SPC1, SID, C,      G
$ Encastre at node 1 — all 6 DOFs fixed
SPC1, 1, 123456, 1
SPC1, 1, 12, 11, 10, 9, 8, 7, 6, 5, 4, 3, 2
$
$ --------------------------------------------------------- EIGENVALUE METHOD
$ EIGRL, SID, V1, V2, ND, MSGLVL, MAXSET, SHFSCL, NORM
$ Extract first 6 modes, MASS normalisation
EIGRL, 20, , , 6, , , , MASS
$
ENDDATA
